# === BIGQUERY (obrigatorio) ===
CREDENTIAL_PATH=credentials/sua-credencial.json
GCP_PROJECT=seu-projeto-gcp
BQ_DATASET=seu_dataset
BQ_LOCATION=southamerica-east1

# === ENTRADA (obrigatorio para headless) ===
INPUT_FILE=data_input/sua_planilha.xlsx
SHEET_NAME=
OUTPUT_DIR=data_output

# === COLUNAS (ajuste conforme layout da planilha) ===
COL_ENDERECO_TABELA=4
COL_DATA_REF_BASE=8
COL_DATA_REF_PAINEL=11

# === MODO RASTREIO (opcional - rastreia origens via SQL do dbt) ===
SQL_SOURCES_DIR=

# === CSV (opcional) ===
CSV_DELIMITER=;
CSV_ENCODING=utf-8-sig

# === AVANCADO (opcional) ===
MAX_RETRIES=3
LOG_DIR=data_output
DBT_PROJECT_DIR=
